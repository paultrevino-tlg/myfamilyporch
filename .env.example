# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-only. NEVER expose to the client.

# ---- Anthropic (server-side only, via /api/ai/*) ----
ANTHROPIC_API_KEY=

# ---- Twilio (SMS nudges + alert-to-admin) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- ElevenLabs (cloned-voice TTS) ----
ELEVENLABS_API_KEY=

# ---- App ----
APP_BASE_URL=http://localhost:3000
STORYTELLER_TOKEN_SECRET=         # HMAC secret for signing magic-link tokens

# For local Cloudflare dev, copy these into .dev.vars as well.
